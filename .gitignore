# ===== EdgeSentry .gitignore =====

# --- Secrets / local config (NEVER commit these) ---
# The Pico's real config with wifi + broker creds
firmware/config.py
# Any local env files
.env
.env.*
*.local

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
# Virtual environments
.venv/
venv/
env/

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/

# --- Terraform ---
# State files can contain secrets and are environment-specific
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# --- Kubernetes / Helm ---
# Rendered/packaged charts
*.tgz

# --- IDE / OS noise ---
.vscode/
.idea/
.DS_Store
*.swp